ee=questHelpers.openQuestLink;
te=questHelpers.renderClozeSentence;
Qe=questHelpers.getQuestImageResource;
Ye=function(n,e){return questHelpers.getQuestTheme(n,e,Y)};
je=questHelpers.getQuestNodePositions;
Ve=function(n,e,t,r,s){return questRender.renderQuestMap(n,e,t,r,s,je)};
Ke=function(n,e,t,r,s,l){return questModal.renderQuestChallenge(n,e,t,r,s,l,{questDifficultyPresets:ye,translateKey:c,getLanguage:L,retriggerShake:V,openQuestLink:ee,collectExpectedAnswers:we,matchesExpectedAnswer:ke,renderClozeSentence:te,getQuestImageResource:Qe})};
Xe=function(n,e,t,r,s,l){return questModal.openQuestChapterModal(n,e,t,r,s,l,{getQuestTheme:Ye,getLanguage:L,renderQuestChallenge:Ke})};
tt=reviewHelpers.advancedSrPattern;
rt=reviewHelpers.legacySrPattern;
