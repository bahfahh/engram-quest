      .premium-card {
        background: #FFFFFF; border: 1px solid rgba(0, 0, 0, 0.06);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02), 0 2px 4px -2px rgba(0, 0, 0, 0.02);
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative; overflow: hidden;
      }
      .premium-card::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
        border: 1px solid rgba(255, 255, 255, 0.6); border-radius: inherit; pointer-events: none;
      }
      .premium-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px -8px rgba(99, 102, 241, 0.12), 0 4px 8px -3px rgba(0, 0, 0, 0.04);
        border-color: rgba(99, 102, 241, 0.2);
      }
      .icon-container {
        display: inline-flex; align-items: center; justify-content: center;
        width: 44px; height: 44px; border-radius: 12px; margin-bottom: 12px;
        background: linear-gradient(135deg, rgba(255,255,255,1), rgba(245,245,245,0.6));
        border: 1px solid rgba(0,0,0,0.04);
        box-shadow: inset 0 2px 4px rgba(255,255,255,0.8), 0 2px 4px rgba(0,0,0,0.02);
      }
      .icon-container svg { width:24px; height:24px; }
      .lh-mm-path.truncate {
