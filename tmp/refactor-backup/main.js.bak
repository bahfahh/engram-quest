.lp-wrap { font-family: system-ui, sans-serif; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.12); }
.lp-clouds { position: relative; height: 0; }
.lp-cloud { position: absolute; background: rgba(255,255,255,0.85); border-radius: 50px; width: 100px; height: 35px; filter: blur(1px); z-index: 1; }
.lp-cloud::before { content:''; position:absolute; background:rgba(255,255,255,0.9); border-radius:50%; width:50px; height:50px; top:-25px; left:12px; }
.lp-cloud::after  { content:''; position:absolute; background:rgba(255,255,255,0.9); border-radius:50%; width:35px; height:35px; top:-15px; left:52px; }
.lp-map { position: relative; background: var(--lp-bg); overflow: auto; }
.lp-node { position: absolute; display: flex; flex-direction: column; align-items: center; cursor: pointer; transition: transform 0.2s; user-select: none; width: 110px; }
.lp-node:hover { transform: scale(1.1) translateY(-4px); }
.lp-island { width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; position: relative; box-shadow: 0 6px 18px rgba(0,0,0,0.2), inset 0 -3px 6px rgba(0,0,0,0.1); border: 2px solid rgba(255,255,255,0.4); }
.lp-emoji { font-size: 32px; }
.lp-badge { position:absolute; top:-4px; right:-4px; width:24px; height:24px; border-radius:50%; background:white; display:flex; align-items:center; justify-content:center; font-size:13px; box-shadow:0 2px 5px rgba(0,0,0,0.25); }
.lp-label { margin-top: 6px; font-size: 12px; font-weight: 600; text-align: center; text-shadow: 0 1px 3px rgba(255,255,255,0.7); line-height: 1.2; }
.lp-mini-bar { width: 70px; height: 5px; background: rgba(0,0,0,0.15); border-radius: 3px; margin-top: 4px; overflow: hidden; }
.lp-mini-bar > div { height: 100%; border-radius: 3px; }
@keyframes lp-pulse { 0%,100%{ filter:drop-shadow(0 0 6px rgba(255,200,50,0.5)); } 50%{ filter:drop-shadow(0 0 18px rgba(255,200,50,1)); } }
.lp-pulse { animation: lp-pulse 2s ease-in-out infinite; }
.lp-panel { background: white; padding: 20px 24px 24px; }
.lp-panel-title { font-size: 18px; font-weight: 700; color: #1a1a2e; margin-bottom: 6px; }
.lp-panel-desc { font-size: 13px; color: #555; margin-bottom: 16px; line-height: 1.6; }
.lp-btn { background: linear-gradient(135deg, #667eea, #764ba2); color: white; border: none; border-radius: 50px; padding: 10px 32px; font-size: 14px; font-weight: 600; cursor: pointer; display: block; width: 100%; max-width: 240px; margin-bottom: 12px; transition: all 0.2s; }
.lp-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 4px 14px rgba(102,126,234,0.5); }
.lp-btn:disabled { background: #ccc; cursor: not-allowed; }
.lp-progress-row { display: flex; align-items: center; gap: 10px; }
.lp-bar-bg { flex: 1; max-width: 180px; height: 7px; background: #e0e0e0; border-radius: 4px; overflow: hidden; }
.lp-bar-fill { height: 100%; border-radius: 4px; transition: width 0.4s; }
.lp-progress-text { font-size: 12px; color: #777; }
/* Quest Map animations */
.qm-scroll-wrapper { width: 100%; overflow-x: auto; overflow-y: hidden; border-radius: 12px; border: 1px solid var(--background-modifier-border); box-shadow: 0 8px 24px rgba(0,0,0,0.08); scrollbar-width: thin; }
.qm-hybrid-container { position: relative; width: 100%; min-width: 1100px; height: 520px; background-size: cover; background-position: center; overflow: hidden; }
.qm-svg-layer { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 1; }
.qm-island-group { position: absolute; z-index: 2; transform: translate(-50%, -50%); display: flex; flex-direction: column; align-items: center; cursor: pointer; transition: filter 0.3s ease; animation: floatIsland 4s ease-in-out infinite; }
@keyframes floatIsland { 0%, 100% { transform: translate(-50%, -50%); } 50% { transform: translate(-50%, calc(-50% - 12px)); } }
.qm-island-group:hover, .qm-active { filter: brightness(1.1) drop-shadow(0 20px 20px rgba(0,0,0,0.3)); z-index: 10; }
.qm-platform { width: 140px; height: auto; object-fit: contain; filter: drop-shadow(0 15px 15px rgba(0, 30, 80, 0.4)); transition: all 0.3s; }
.qm-active .qm-platform { width: 160px; filter: drop-shadow(0 20px 25px rgba(0, 100, 200, 0.4)) brightness(1.2); }
.qm-diff-boss .qm-platform { width: 170px; filter: drop-shadow(0 20px 25px rgba(150, 0, 150, 0.5)) hue-rotate(240deg) brightness(0.85) contrast(1.2); }
.qm-style-forest .qm-platform { filter: drop-shadow(0 15px 15px rgba(0, 80, 30, 0.4)) hue-rotate(-110deg) saturate(1.2); }
.qm-style-galaxy .qm-platform { filter: drop-shadow(0 15px 15px rgba(60, 0, 80, 0.4)) hue-rotate(80deg) saturate(1.5); }
.qm-visited .qm-platform { filter: brightness(0.65) sepia(0.3); }
.qm-label-wrap { margin-top: -10px; background: rgba(255, 255, 255, 0.95); padding: 6px 16px; border-radius: 20px; font-size: 13px; font-weight: 700; color: #1e293b; box-shadow: 0 4px 6px rgba(0,0,0,0.1); position: relative; z-index: 10; }
.qm-active .qm-label-wrap { border: 2px solid #3b82f6; }
.qm-emoji { position: absolute; top: -55px; left: 50%; transform: translateX(-50%); font-size: 32px; width: 60px; height: 60px; background: linear-gradient(135deg, rgba(255,255,255,0.4), rgba(255,255,255,0.1)); border: 2px solid rgba(255,255,255,0.6); backdrop-filter: blur(4px); border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 16px rgba(0,0,0,0.2); z-index: 5; transition: transform 0.2s; }
.qm-island-group:hover .qm-emoji { transform: translateX(-50%) scale(1.15); }
.qm-icon-prop { position: absolute; top: -55px; left: 50%; transform: translateX(-50%); width: 65px; height: 65px; object-fit: contain; filter: drop-shadow(0 8px 10px rgba(0,0,0,0.3)); z-index: 5; animation: floatProp 3s ease-in-out infinite; transition: transform 0.2s ease; }
.qm-island-group:hover .qm-icon-prop { transform: translateX(-50%) scale(1.15); }
.qm-icon-boss { top: -85px; width: 100px; height: 100px; filter: drop-shadow(0 15px 25px rgba(255, 200, 0, 0.4)); }
@keyframes floatProp { 0%, 100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(-8px); } }
.qm-current-badge { position: absolute; top: -80px; left: 50%; transform: translateX(-50%); background: #0f172a; color: white; font-size: 10px; font-weight: 700; padding: 4px 10px; border-radius: 12px; border: 1px solid #4ade80; display: flex; align-items: center; gap: 4px; z-index: 6; box-shadow: 0 4px 10px rgba(74, 222, 128, 0.3); }
.qm-current-badge::before { content: ""; display: inline-block; width: 6px; height: 6px; background: #4ade80; border-radius: 50%; box-shadow: 0 0 5px #4ade80; animation: qmpulseDot 1.5s infinite; }
@keyframes qmpulseDot { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
@keyframes dashFlow { to { stroke-dashoffset: -26; } }
.qm-visited-badge { position: absolute; top:-60px; left:30px; background:#4ade80; color:white; width:22px; height:22px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:bold; border:2px solid white; z-index:6; }
@keyframes qm-bounce { 0%{transform:translate(-50%,-50%) scale(1)} 50%{transform:translate(-50%,calc(-50% - 15px)) scale(1.05)} 100%{transform:translate(-50%,-50%) scale(1)} }
.qm-bounce { animation: qm-bounce 0.4s ease-out; }
@keyframes qm-modal-in { from{opacity:0;transform:scale(0.94) translateY(12px)} to{opacity:1;transform:scale(1) translateY(0)} }
@keyframes qm-celebrate-in  { from{opacity:0;transform:scale(0.8)} to{opacity:1;transform:scale(1)} }
@keyframes qm-celebrate-out { 0%{opacity:1} 100%{opacity:0} }
@keyframes qm-shake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-7px)} 40%{transform:translateX(7px)} 60%{transform:translateX(-4px)} 80%{transform:translateX(4px)} }
.qm-shake { animation: qm-shake 0.4s ease-in-out; }
.qm-ch-btn { border-radius:8px;padding:10px 14px;font-size:13px;font-weight:600;cursor:pointer;border:1.5px solid var(--background-modifier-border);background:var(--background-primary);color:var(--text-normal);transition:all 0.15s;text-align:left;width:100%; }
.qm-ch-btn:hover:not(:disabled) { border-color:var(--interactive-accent);background:var(--background-secondary); }
.qm-ch-btn.qm-selected { border-color:var(--interactive-accent);background:var(--background-secondary);color:var(--interactive-accent);font-weight:700; }
.qm-ch-input { flex:1;padding:10px 14px;border-radius:8px;border:1.5px solid var(--background-modifier-border);background:var(--background-primary);color:var(--text-normal);font-size:13px;outline:none; }
.qm-ch-input:focus { border-color:var(--interactive-accent); }
.qm-ch-chip { border-radius:20px;padding:7px 16px;font-size:13px;cursor:pointer;border:1.5px solid var(--background-modifier-border);background:var(--background-primary);color:var(--text-normal);transition:all 0.15s; }
.qm-ch-chip:hover:not(:disabled) { border-color:var(--interactive-accent); }
.qm-ch-chip:disabled { opacity:0.35;cursor:not-allowed; }
/* Review Deck */
.rd-wrap { font-family:system-ui,sans-serif; }
.rd-stats { display:flex;flex-wrap:wrap;gap:12px;padding:10px 14px;background:var(--background-secondary);border-radius:10px;margin-bottom:12px;font-size:13px;color:var(--text-muted); }
.rd-title { font-size:16px;font-weight:700;color:var(--text-normal);margin-bottom:12px; }
.rd-grid { display:grid;gap:10px;margin-top:4px; }
.rd-card { aspect-ratio:2/3;border-radius:12px;cursor:pointer;position:relative;transition:transform .18s,box-shadow .18s;overflow:hidden; }
.rd-card:hover { transform:translateY(-4px) scale(1.03);box-shadow:0 8px 24px rgba(0,0,0,0.18); }
.rd-card-face { position:absolute;inset:0;border-radius:inherit;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px; }
.rd-card-emoji { font-size:28px;line-height:1; }
.rd-card-state { position:absolute;top:6px;right:6px;font-size:14px; }
@keyframes rd-glow { 0%,100%{box-shadow:0 0 8px rgba(245,158,11,0.4)} 50%{box-shadow:0 0 20px rgba(245,158,11,0.8)} }
.rd-due-glow { animation:rd-glow 1.8s ease-in-out infinite; }
.rd-modal-hint { border-radius:10px;padding:14px 16px;margin-bottom:8px; }
.rd-rating-row { display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:4px; }
.rd-rating-btn { border-radius:10px;padding:12px 6px;font-size:13px;font-weight:700;cursor:pointer;border:none;color:white;display:flex;flex-direction:column;align-items:center;gap:4px;transition:filter .15s; }
.rd-rating-btn:hover { filter:brightness(1.12); }
.rd-rating-btn small { font-size:11px;font-weight:400;opacity:0.88; }
.rd-action-btn { border-radius:8px;padding:10px 20px;font-size:14px;font-weight:600;cursor:pointer;transition:all .15s;width:100%; }
/* Isolate plugin controls from theme CSS so Obsidian or snippet styles do not override component behavior. */
/* :where() keeps specificity at zero, which lets component-specific classes still win when needed. */
:where(.lh-hub) button,:where(.lh-hub) input,:where(.lh-hub) select,:where(.lh-hub) textarea { all:unset;box-sizing:border-box;cursor:pointer; }
:where(.lh-hub) input,:where(.lh-hub) textarea { cursor:text; }
/* Shared animations and primitives reused across hub, decks, and maps. */
@keyframes lh-fadeslide { from{opacity:0;transform:translateY(-6px)} to{opacity:1;transform:translateY(0)} }
@keyframes lh-glow-due { 0%,100%{box-shadow:0 0 0 rgba(99,102,241,0)} 50%{box-shadow:0 0 18px rgba(99,102,241,0.45)} }
/* Hub navigation bar */
.lh-nav { display:flex;align-items:center;gap:8px;padding:10px 16px;flex-shrink:0;border-bottom:2px solid #e5e7eb;background:#ffffff !important;color:#1f2937 !important;position:relative; }
.lh-logo { font-size:12px;font-weight:800;letter-spacing:.08em;color:#9ca3af !important;text-transform:uppercase;margin-right:8px;white-space:nowrap; }
.lh-tabs { display:flex;gap:4px;flex:1; }
.lh-tab { display:flex;align-items:center;gap:6px;padding:8px 16px;border-radius:99px;border:1.5px solid #e5e7eb !important;background:#ffffff !important;color:#6b7280 !important;font-size:13px;font-weight:600;cursor:pointer;transition:all .18s;white-space:nowrap;position:relative; }
.lh-tab:hover:not(.active) { border-color:#a5b4fc !important;color:#6366f1 !important;transform:translateY(-1px); }
.lh-tab:active { transform:scale(0.95) !important; }
.lh-tab.active { background:#ffffff !important;border-color:#6366f1 !important;color:#6366f1 !important;font-weight:700; }
.lh-tab.active::after { content:'';position:absolute;bottom:-12px;left:20%;width:60%;height:3px;background:linear-gradient(90deg,#6366f1,#818cf8);border-radius:99px; }
.lh-close { margin-left:auto;width:32px;height:32px;border-radius:50%;border:1.5px solid #e5e7eb !important;background:#ffffff !important;color:#9ca3af !important;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0; }
.lh-close:hover { background:#fee2e2 !important;border-color:#fca5a5 !important;color:#ef4444 !important; }
.lh-close:active { transform:scale(0.9); }
/* Stats header */
.lh-stats-header { position:relative;height:220px;flex-shrink:0;background-size:cover;background-position:center 20%;overflow:hidden; }
.lh-stat-grp { position:absolute;display:flex;flex-direction:column;align-items:center;gap:2px;transform:translate(-50%,-50%); }
.lh-stat-label { font-size:11px;font-weight:700;color:#fff !important;text-shadow:0 1px 6px rgba(0,0,0,0.9),0 0 12px rgba(0,0,0,0.6);letter-spacing:.06em;text-transform:uppercase; }
.lh-stat-num { font-weight:900;line-height:1;text-shadow:0 2px 20px rgba(0,0,0,0.7),0 0 40px rgba(0,0,0,0.4),-1px -1px 0 rgba(0,0,0,0.2),1px 1px 0 rgba(0,0,0,0.2); }
.lh-stat-num.ready { font-size:58px;color:#86efac !important; }
.lh-stat-num.due   { font-size:52px;color:#86efac !important; }
.lh-stat-num.new   { font-size:52px;color:#93c5fd !important; }
.lh-stat-num.total { font-size:52px;color:#fde68a !important; }
.lh-stats-helper { position:absolute;left:50%;bottom:18px;transform:translateX(-50%);padding:6px 12px;border-radius:999px;background:rgba(255,255,255,0.16) !important;color:#ffffff !important;font-size:11px;font-weight:600;backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);box-shadow:0 6px 16px rgba(0,0,0,0.14);white-space:nowrap; }
/* White content card */
.lh-card { background:#f8faff !important;border-radius:24px 24px 0 0;margin-top:-100px;flex:1;overflow-y:auto;padding:0;color:#1f2937 !important;box-shadow:0 -10px 30px rgba(0,0,0,0.18);position:relative;z-index:2; }
.lh-card-header { display:flex;align-items:center;justify-content:space-between;padding:20px 24px 12px; }
.lh-card-title { font-size:14px;font-weight:700;color:#374151 !important; }
.lh-study-all { display:flex;align-items:center;gap:5px;padding:8px 18px;border-radius:99px;border:1.5px solid #d8b4fe !important;background:#faf5ff !important;color:#7c3aed !important;font-size:13px;font-weight:700;cursor:pointer;transition:all .15s; }
.lh-study-all:hover { background:#ede9fe !important;border-color:#a78bfa !important;transform:translateY(-1px); }
.lh-study-all:active { transform:scale(0.96); }
/* Toolbar */
.lh-toolbar { display:flex;align-items:center;gap:8px;padding:0 16px 12px; }
.lh-search { flex:1;display:flex;align-items:center;gap:6px;background:#ffffff !important;border:1.5px solid #e5e7eb !important;border-radius:10px;padding:8px 12px;transition:border-color .15s; }
.lh-search:focus-within { border-color:#a5b4fc !important; }
.lh-search-icon { color:#9ca3af !important;font-size:13px;flex-shrink:0; }
.lh-search input { border:none !important;background:transparent !important;outline:none;font-size:13px;color:#374151 !important;width:100%;display:block; }
.lh-search input::placeholder { color:#9ca3af !important; }
.lh-filter { padding:8px 12px;border-radius:10px;border:1.5px solid #e5e7eb !important;background:#ffffff !important;color:#374151 !important;font-size:12px;font-weight:600;cursor:pointer;outline:none; }
.lh-view-toggle { display:flex;gap:2px;background:#f3f4f6 !important;border-radius:8px;padding:2px; }
.lh-view-btn { width:34px;height:34px;border-radius:7px;background:transparent !important;color:#9ca3af !important;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px;transition:all .15s; }
.lh-view-btn.active { background:#ffffff !important;color:#6366f1 !important;box-shadow:0 1px 4px rgba(0,0,0,0.12); }
.lh-view-btn:active { transform:scale(0.88); }
/* Deck list */
.lh-deck-list { display:flex;flex-direction:column; }
.lh-deck-row { display:flex;align-items:center;gap:14px;padding:14px 24px;border-top:1px solid #e9ecf0 !important;cursor:pointer;transition:background .12s;background:transparent !important; }
.lh-deck-row:hover { background:#f0f4ff !important; }
.lh-deck-row:active { background:#dbeafe !important; }
.lh-deck-row.is-emptyready { opacity:.72; }
.lh-deck-row.is-emptyready:hover { background:#f8fafc !important; }
.lh-deck-row.is-emptyready:active { background:#eef2ff !important; }
.lh-deck-chevron { color:#9ca3af !important;font-size:12px;margin-right:14px;transition:all .15s; }
.lh-deck-row:hover .lh-deck-chevron { color:#6366f1 !important;transform:translateX(3px); }
.lh-deck-main { flex:1;min-width:0;display:flex;flex-direction:column;gap:3px; }
.lh-deck-row-name { font-size:14px;font-weight:700;color:#1f2937 !important; }
.lh-deck-row-sub { font-size:11px;color:#6b7280 !important; }
.lh-deck-metrics { display:flex;align-items:stretch;gap:8px;flex-shrink:0; }
.lh-deck-ready { min-width:88px;border-radius:14px;padding:8px 10px;background:linear-gradient(135deg,#ecfccb,#dcfce7) !important;border:1.5px solid #86efac !important;display:flex;flex-direction:column;align-items:center;justify-content:center; }
.lh-deck-ready.is-zero { background:linear-gradient(135deg,#f8fafc,#eef2ff) !important;border-color:#cbd5e1 !important; }
.lh-deck-ready-label { font-size:10px;font-weight:800;letter-spacing:.06em;text-transform:uppercase;color:#15803d !important; }
.lh-deck-ready.is-zero .lh-deck-ready-label { color:#64748b !important; }
.lh-deck-ready-num { font-size:28px;font-weight:900;line-height:1;color:#166534 !important; }
.lh-deck-ready.is-zero .lh-deck-ready-num { color:#475569 !important; }
.lh-deck-breakdown { display:grid;grid-template-columns:repeat(3,minmax(54px,1fr));gap:6px; }
.lh-deck-metric { border-radius:12px;padding:7px 8px;background:#ffffff !important;border:1.5px solid #e5e7eb !important;display:flex;flex-direction:column;align-items:center;justify-content:center;min-width:56px; }
.lh-deck-metric-label { font-size:10px;font-weight:700;color:#94a3b8 !important;text-transform:uppercase;letter-spacing:.04em; }
.lh-deck-metric-num { font-size:16px;font-weight:800;color:#334155 !important;line-height:1.1; }
.lh-deck-metric.due .lh-deck-metric-num { color:#16a34a !important; }
.lh-deck-metric.new .lh-deck-metric-num { color:#2563eb !important; }
.lh-deck-metric.total .lh-deck-metric-num { color:#d97706 !important; }
/* Deck grid */
.lh-deck-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;padding:12px 20px; }
.lh-deck-gc { background:#fff !important;border-radius:16px;padding:16px 14px;cursor:pointer;border:1.5px solid #e5e7eb !important;transition:all .2s;display:flex;flex-direction:column;gap:8px;box-shadow:0 2px 8px rgba(0,0,0,0.06);color:#1f2937 !important; }
.lh-deck-gc:hover { transform:translateY(-3px);border-color:#a5b4fc !important;box-shadow:0 8px 20px rgba(99,102,241,0.15); }
.lh-deck-gc:active { transform:translateY(-1px); }
.lh-deck-gc.has-due { animation:lh-glow-due 2s ease-in-out infinite; }
.lh-deck-gc.is-emptyready { opacity:.78; }
.lh-deck-gc.is-emptyready:hover { transform:none;border-color:#e5e7eb !important;box-shadow:0 2px 8px rgba(0,0,0,0.06); }
.lh-deck-gc.is-emptyready:active { transform:none; }
.lh-deck-gc-emoji { font-size:28px; }
.lh-deck-gc-name { font-size:13px;font-weight:700;color:#1f2937 !important; }
.lh-deck-gc-bar-bg { background:#e5e7eb !important;border-radius:99px;height:4px;overflow:hidden; }
.lh-deck-gc-bar { height:100%;border-radius:99px;background:linear-gradient(90deg,#818cf8,#6366f1) !important;transition:width .4s; }
.lh-deck-gc-sub { font-size:10px;color:#9ca3af !important; }
.lh-deck-gc-status { font-size:11px;font-weight:700;color:#475569 !important; }
.lh-deck-gc-ready { display:flex;align-items:baseline;gap:6px; }
.lh-deck-gc-ready-num { font-size:32px;font-weight:900;line-height:1;color:#166534 !important; }
.lh-deck-gc.is-emptyready .lh-deck-gc-ready-num { color:#475569 !important; }
.lh-deck-gc-ready-label { font-size:11px;font-weight:800;letter-spacing:.06em;text-transform:uppercase;color:#15803d !important; }
.lh-deck-gc.is-emptyready .lh-deck-gc-ready-label { color:#64748b !important; }
.lh-deck-gc-metrics { display:grid;grid-template-columns:repeat(3,1fr);gap:6px; }
.lh-deck-gc-metric { border-radius:10px;padding:6px 4px;background:#f8fafc !important;border:1px solid #e5e7eb !important;display:flex;flex-direction:column;align-items:center;gap:2px; }
.lh-deck-gc-metric-label { font-size:9px;font-weight:700;color:#94a3b8 !important;text-transform:uppercase; }
.lh-deck-gc-metric-num { font-size:13px;font-weight:800;color:#334155 !important; }
.lh-deck-gc-metric.due .lh-deck-gc-metric-num { color:#16a34a !important; }
.lh-deck-gc-metric.new .lh-deck-gc-metric-num { color:#2563eb !important; }
.lh-deck-gc-metric.total .lh-deck-gc-metric-num { color:#d97706 !important; }
/* Empty state and shared tab cards */
.lh-empty { padding:48px 24px;text-align:center;color:#9ca3af !important;font-size:14px;line-height:1.9; }
.lh-card-count { font-size:12px;font-weight:600;color:#9ca3af !important;background:#f3f4f6 !important;border-radius:99px;padding:3px 10px; }
.lh-tab-list { display:flex;flex-direction:column;padding:0 0 16px; }
.lh-tab-list-item { display:flex;align-items:center;gap:12px;padding:13px 20px;border-bottom:1px solid #f1f5f9 !important;cursor:pointer;transition:background .12s; }
.lh-tab-list-item:hover { background:#f0f4ff !important; }
.lh-tab-list-item:active { background:#dbeafe !important; }
.lh-tab-list-emoji { font-size:20px; }
.lh-tab-list-title { font-size:14px;font-weight:600;color:#1f2937 !important; }
.lh-tab-list-sub { font-size:11px;color:#9ca3af !important;margin-top:1px; }
.lh-tab-list-badge { border-radius:6px;padding:3px 10px;font-size:11px;font-weight:700;color:#fff !important;background:#6366f1 !important; }
/* Memory Map grid */
.lh-mm-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px; }
.lh-mm-card { background:#fff !important;border-radius:16px;padding:16px 14px;cursor:pointer;border:1.5px solid #e5e7eb !important;transition:all .2s;display:flex;flex-direction:column;gap:6px;box-shadow:0 2px 8px rgba(0,0,0,0.05); }
.lh-mm-card:hover { transform:translateY(-3px);border-color:#a5b4fc !important;box-shadow:0 8px 20px rgba(99,102,241,0.15); }
.lh-mm-card:active { transform:translateY(-1px); }
.lh-mm-emoji { font-size:28px; }
.lh-mm-name { font-size:13px;font-weight:700;color:#1f2937 !important;line-height:1.3; }
.lh-mm-path { font-size:10px;color:#9ca3af !important; }
.lh-mm-open { font-size:11px;font-weight:600;color:#6366f1 !important;margin-top:4px; }
/* Review modal */
.lh-review-nav { display:flex;align-items:center;gap:8px;padding:11px 16px;background:rgba(255,255,255,0.82) !important;backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom:1px solid rgba(255,255,255,0.5);flex-shrink:0; }
.lh-review-logo { font-size:11px;font-weight:800;color:#4f46e5 !important;letter-spacing:.05em;text-transform:uppercase;white-space:nowrap;margin-right:6px; }
.lh-review-tabs { display:flex;gap:5px; }
.lh-review-tab { display:flex;align-items:center;gap:5px;padding:6px 14px;border-radius:99px;border:1.5px solid #e5e7eb !important;background:#ffffff !important;color:#6b7280 !important;font-size:12px;font-weight:600;cursor:pointer;transition:all .18s;white-space:nowrap; }
.lh-review-tab:hover:not(.active) { border-color:#a5b4fc !important;color:#6366f1 !important; }
.lh-review-tab.active { background:#4f46e5 !important;border-color:#4f46e5 !important;color:#ffffff !important;font-weight:700;box-shadow:0 3px 10px rgba(79,70,229,0.35); }
.lh-review-tab:active { transform:scale(0.95); }
.lh-review-body { padding:14px 14px 8px;flex:1;display:flex;flex-direction:column;min-height:0;overflow:hidden; }
.lh-review-card { background:rgba(255,255,255,0.97) !important;border-radius:22px;padding:22px 24px;box-shadow:0 8px 40px rgba(0,0,0,0.14);flex:1;min-height:0;overflow-y:auto;color:#1f2937 !important; }
.lh-rc-top { display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px;gap:12px; }
.lh-rc-badge { background:linear-gradient(135deg,#ede9fe,#ddd6fe) !important;color:#6366f1 !important;border-radius:99px;padding:5px 16px;font-size:12px;font-weight:700;flex-shrink:0; }
.lh-rc-emoji { font-size:38px;line-height:1;flex-shrink:0; }
.lh-rc-question { font-size:22px;font-weight:800;color:#1e293b !important;line-height:1.5;flex:1; }
.lh-hint { border-radius:12px;padding:13px 16px;margin-top:10px;animation:lh-fadeslide .28s ease; }
.lh-hint-label { font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px; }
.lh-hint-text { font-size:14px;line-height:1.65; }
.lh-hint-l1 { background:#eff6ff !important;border-left:3px solid #3b82f6; }
.lh-hint-l1 .lh-hint-label { color:#3b82f6 !important; }
.lh-hint-l1 .lh-hint-text { color:#1e40af !important; }
.lh-hint-l2 { background:#f0fdf4 !important;border-left:3px solid #22c55e; }
.lh-hint-l2 .lh-hint-label { color:#22c55e !important; }
.lh-hint-l2 .lh-hint-text { color:#15803d !important; }
.lh-hint-l3 { background:#fffbeb !important;border-left:3px solid #f59e0b; }
.lh-hint-l3 .lh-hint-label { color:#f59e0b !important; }
.lh-hint-l3 .lh-hint-text { color:#92400e !important; }
.lh-answer-block { background:#faf5ff !important;border-left:3px solid #8b5cf6;border-radius:12px;padding:14px 18px;margin-top:10px;animation:lh-fadeslide .28s ease; }
.lh-answer-label { font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;color:#8b5cf6 !important;margin-bottom:6px; }
.lh-answer-text { font-size:15px;color:#4c1d95 !important;line-height:1.7; }
/* Three pill buttons before the answer is shown */
.lh-review-footer { display:flex;flex-direction:column;gap:8px;padding:10px 14px 0; }
.lh-pill-row { display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px; }
.lh-pill-btn { display:flex;align-items:center;justify-content:center;gap:7px;padding:0 12px;border-radius:99px;font-size:15px;font-weight:700;cursor:pointer;transition:all .18s;white-space:nowrap;min-height:54px; }
.lh-pill-btn:hover { transform:translateY(-2px);filter:brightness(1.07); }
.lh-pill-btn:active { transform:scale(0.95) translateY(0) !important;filter:brightness(0.93) !important; }
.lh-pill-show { background:#f1f5f9 !important;color:#475569 !important;border:2px solid #e2e8f0 !important; }
.lh-pill-show:hover { background:#e8eef5 !important; }
.lh-pill-recall { background:linear-gradient(135deg,#4f46e5,#818cf8) !important;color:#ffffff !important;box-shadow:0 4px 16px rgba(79,70,229,0.45); }
.lh-pill-memory { background:linear-gradient(135deg,#f59e0b,#fbbf24) !important;color:#ffffff !important;box-shadow:0 4px 16px rgba(245,158,11,0.4); }
.lh-pill-memory:disabled { opacity:.38;cursor:not-allowed;transform:none !important;filter:none !important;box-shadow:none !important; }
.lh-footer-meta { display:flex;align-items:center;justify-content:center;gap:14px; }
.lh-pill-reset { display:flex;align-items:center;justify-content:center;width:36px;height:36px;background:rgba(255,255,255,0.7) !important;color:#64748b !important;border:1.5px solid rgba(203,213,225,0.9) !important;border-radius:50%;font-size:16px;cursor:pointer;transition:all .18s; }
.lh-pill-reset:hover { background:rgba(255,255,255,0.95) !important;transform:rotate(45deg); }
.lh-dots { display:flex;gap:7px;align-items:center; }
.lh-dot { width:9px;height:9px;border-radius:50%;background:rgba(255,255,255,0.45) !important;border:1.5px solid rgba(200,215,235,0.8);transition:all .25s; }
.lh-dot.lit { background:#4f46e5 !important;border-color:#4f46e5 !important;box-shadow:0 0 8px rgba(79,70,229,0.6); }
/* Progress bar area */
.lh-review-progress { padding:8px 14px 14px;display:flex;flex-direction:column;align-items:center;gap:6px;flex-shrink:0; }
.lh-review-prog-wrap { width:100%;background:rgba(255,255,255,0.35) !important;height:8px;border-radius:99px;overflow:hidden; }
.lh-review-prog-bar { height:100%;border-radius:99px;background:linear-gradient(90deg,#4f46e5,#a78bfa) !important;transition:width .4s; }
.lh-review-badge { background:rgba(255,255,255,0.92) !important;border-radius:99px;padding:5px 16px;font-size:12px;font-weight:700;color:#4f46e5 !important;box-shadow:0 2px 8px rgba(0,0,0,0.1); }
.lh-browse-note { margin-top:10px;padding:10px 12px;border-radius:14px;background:#eff6ff !important;border:1px solid #bfdbfe !important;color:#1d4ed8 !important;font-size:12px;font-weight:600; }
.lh-browse-row { display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;padding:10px 14px 14px; }
.lh-browse-btn { border-radius:12px;padding:12px 10px;background:#ffffff !important;border:1.5px solid #dbeafe !important;color:#1e3a8a !important;font-size:13px;font-weight:700;text-align:center; }
.lh-browse-btn:hover:not(:disabled) { background:#eff6ff !important;border-color:#93c5fd !important; }
.lh-browse-btn:disabled { opacity:.45;cursor:not-allowed; }
/* Review back button */
.lh-review-back { margin-left:auto;display:flex;align-items:center;gap:6px;padding:8px 18px;border-radius:99px;border:2px solid #6366f1 !important;background:#ffffff !important;color:#6366f1 !important;font-size:13px;font-weight:700;cursor:pointer;transition:all .18s;flex-shrink:0; }
.lh-review-back:hover { background:#ede9fe !important;border-color:#4f46e5 !important;color:#4f46e5 !important;transform:translateX(-2px);box-shadow:0 2px 10px rgba(99,102,241,0.25); }
.lh-review-back:active { transform:scale(0.95); }
/* Rating buttons after the answer is revealed */
.lh-rating-row { display:grid;grid-template-columns:repeat(4,1fr);gap:10px;padding:10px 14px 14px; }
.lh-rating-btn { display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;border-radius:20px;padding:14px 8px 12px;cursor:pointer;color:#ffffff !important;transition:all .2s;min-height:72px;position:relative;overflow:hidden; }
.lh-rating-btn::before { content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(255,255,255,0.22) 0%,rgba(255,255,255,0) 60%);pointer-events:none; }
.lh-rating-btn:hover { transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,0.28) !important; }
.lh-rating-btn:active { filter:brightness(0.88) !important;transform:scale(0.95) translateY(0) !important; }
.lh-rb-top { display:flex;align-items:center;gap:5px;position:relative; }
.lh-rb-icon { font-size:14px;line-height:1; }
.lh-rb-label { font-size:15px;font-weight:800; }
.lh-rb-days { font-size:11px;font-weight:600;opacity:.88;position:relative; }
.lh-rb-again { background:linear-gradient(145deg,#f87171,#dc2626) !important;box-shadow:0 4px 16px rgba(220,38,38,0.4); }
.lh-rb-hard  { background:linear-gradient(145deg,#fbbf24,#d97706) !important;box-shadow:0 4px 16px rgba(217,119,6,0.4); }
.lh-rb-good  { background:linear-gradient(145deg,#60a5fa,#2563eb) !important;box-shadow:0 4px 16px rgba(37,99,235,0.4); }
.lh-rb-easy  { background:linear-gradient(145deg,#4ade80,#16a34a) !important;box-shadow:0 4px 16px rgba(22,163,74,0.4); }
`,q=[{id:"ch1-why",titleEn:"Why Harness?",titleZh:"Why Harness?",emoji:"MAP",themeColor:"blue",summary:"A strong model alone is not enough. Reliable agents need structure around the model so work stays consistent, testable, and recoverable.",keyPoints:[{title:"Context drift",why:"Agents fail when the right context is missing or mixed with irrelevant detail.",example:"A coding agent edits the wrong file because the repo constraints were never loaded."},{title:"Weak self-checking",why:"Without checks, an agent often assumes it is correct and moves on too early.",example:"The patch compiles locally but breaks the real workflow because no verification step ran."},{title:"Harness as control layer",why:"A harness adds instructions, guardrails, state, and feedback loops around the model.",example:"AGENTS.md, tests, and progress files keep the agent aligned with the task."}],realWorld:"Teams using structured agent workflows typically get more predictable output than teams relying on prompts alone."},{id:"ch2-three-pillars",titleEn:"Three Pillars",titleZh:"Three Pillars",emoji:"TRI",themeColor:"green",summary:"Harness engineering usually rests on three pillars: context engineering, architectural constraints, and feedback loops.",keyPoints:[{title:"Context engineering",why:"Give the agent the minimum correct context at the correct time.",example:"Load specs, current task state, and file ownership before asking for edits."},{title:"Architectural constraints",why:"Clear boundaries reduce destructive or low-quality actions.",example:"Require non-interactive git usage and forbid unsafe resets."},{title:"Feedback loops",why:"Verification closes the gap between looks done and actually works.",example:"Run syntax checks and targeted tests before declaring success."}],realWorld:"The biggest reliability jump often comes from adding lightweight verification rather than adding more prompt text."},{id:"ch3-principles",titleEn:"Design Principles",titleZh:"Design Principles",emoji:"RULE",themeColor:"amber",summary:"Good harnesses do not try to micromanage every step. They shape decisions so the agent can act quickly without drifting.",keyPoints:[{title:"Specify what and why",why:"Tell the agent the goal and constraints clearly; avoid over-prescribing every keystroke.",example:"Fix the Review Deck scan default and preserve migration behavior."},{title:"Make failure visible",why:"If something breaks, the system should expose it early.",example:"A syntax check catches broken strings before the plugin reaches runtime."},{title:"Prefer observable progress",why:"Visible state helps both humans and agents recover from interruptions.",example:"A now.md note records product decisions and implementation status."}],realWorld:"The best agent systems feel boring in production: fewer surprises, clearer boundaries, faster recovery."},{id:"ch4-scale",titleEn:"Scale & Teams",titleZh:"Scale and Teams",emoji:"TEAM",themeColor:"purple",summary:"As more agents or teammates join, coordination matters more than raw model quality.",keyPoints:[{title:"Shared rules",why:"Teams need one source of truth for conventions and safety rules.",example:"AGENTS.md and PROJECT_TRUTH.md define workflow expectations."},{title:"Scoped ownership",why:"Parallel work is safer when responsibilities are explicit.",example:"One agent owns docs while another owns runtime UI fixes."},{title:"Reviewable outputs",why:"People must be able to inspect and trust what the agent changed.",example:"Small diffs and reproducible checks beat giant opaque rewrites."}],realWorld:"Scaling agents is usually a coordination problem before it becomes a model problem."},{id:"ch5-future",titleEn:"The Future",titleZh:"The Future",emoji:"NEXT",themeColor:"slate",isBoss:!0,summary:"The frontier is moving from prompt better toward design better systems around the model.",keyPoints:[{title:"Model plus system",why:"Capability comes from the combination of model, tools, memory, and verification.",example:"A smaller model with a good harness can outperform a larger model used carelessly."},{title:"Long-running workflows",why:"Persistent state and checkpointing matter for multi-step work.",example:"A project note preserves decisions across debugging sessions."},{title:"Human steering",why:"Humans should define direction and quality bars; agents should execute within them.",example:"The user sets product behavior, the agent implements and verifies it."}],realWorld:"Reliable agent products will be differentiated less by raw model access and more by workflow design."}],ae={blue:{g1:"#93c5fd",g2:"#3b82f6",depth:"#1e3a8a",light:"#bfdbfe"},green:{g1:"#86efac",g2:"#22c55e",depth:"#14532d",light:"#bbf7d0"},amber:{g1:"#fde047",g2:"#f59e0b",depth:"#78350f",light:"#fef08a"},purple:{g1:"#d8b4fe",g2:"#a855f7",depth:"#581c87",light:"#e9d5ff"},slate:{g1:"#cbd5e1",g2:"#64748b",depth:"#0f172a",light:"#e2e8f0"}},H=[{cx:100,cy:155},{cx:300,cy:255},{cx:500,cy:95},{cx:700,cy:255},{cx:900,cy:145}];function Ue(){let n=`M ${H[0].cx} ${H[0].cy} `;for(let e=0;e<H.length-1;e++){let t=H[e],r=H[e+1],s=r.cx-t.cx;n+=`C ${t.cx+s*.65} ${t.cy}, ${r.cx-s*.65} ${r.cy}, ${r.cx} ${r.cy} `}return n}function We(n){let e=Ue(),t="",r="";return q.forEach((s,l)=>{let a=ae[s.themeColor];t+=`
