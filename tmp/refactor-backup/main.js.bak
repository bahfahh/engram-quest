lt=function(n,e){return reviewDecks.scanReviewDecks(n,e,reviewHelpers)};
st=function(n,e){return reviewRender.renderReviewDeck(n,e,Y,c,$)};
nt=function(n,e,t,r){return reviewModal.openReviewCardModal(n,e,t,r,{computeFsrs:P,translate:c,anySrPattern:ge})};
module.exports=he;
